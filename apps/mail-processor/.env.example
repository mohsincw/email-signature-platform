# ─────────────────────────────────────────────────────────────────────
# Chaiiwala mail relay — environment variables
#
# Copy to .env on the droplet and fill in the real values:
#     cp .env.example .env
#     nano .env
# ─────────────────────────────────────────────────────────────────────

# The public hostname of this relay. Must match the A record you
# created and the subject of the Let's Encrypt certificate.
HOSTNAME=mail-relay.chaiiwala.co.uk

# Email used by certbot for renewal reminders.
CERTBOT_EMAIL=mohsin@chaiiwala.co.uk

# ─── Database (Supabase) ─────────────────────────────────────────────
# Use the same DATABASE_URL as the admin-web Vercel deployment. The
# relay reads from `senders` + `global_settings` tables only.
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ─── Smart host (Exchange Online inbound connector) ─────────────────
# Microsoft's MX endpoint for the chaiiwala.co.uk domain. Find by
# running `dig mx chaiiwala.co.uk` — the answer is usually of the
# form <tenant>-<tld>.mail.protection.outlook.com.
SMART_HOST_HOST=chaiiwala-co-uk.mail.protection.outlook.com
SMART_HOST_PORT=25

# ─── Listener ports (leave defaults unless you know you need them) ──
SMTP_PORT=25
SUBMISSION_PORT=587
HEALTH_PORT=8080

# ─── TLS cert paths (set by certbot automatically) ──────────────────
TLS_CERT_PATH=/etc/letsencrypt/live/mail-relay.chaiiwala.co.uk/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/mail-relay.chaiiwala.co.uk/privkey.pem

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production

# ─── Monitoring (see README "Monitoring & alerting" section) ────────
# Heartbeat URL from your external uptime monitor (UptimeRobot,
# Better Stack, etc.). The smtp-health-probe.sh cron pings this URL
# every 5 min when all checks pass; the monitor alerts on missed
# pings. Leave blank to disable.
HEARTBEAT_URL=
# Optional overrides for the probe (defaults are sensible):
# PROBE_FROM=monitor@chaiiwala.co.uk
# PROBE_TO=mohsin@chaiiwala.co.uk

# ─── Auto-disable (see README "Auto-disable" section) ───────────────
# How many consecutive probe failures before the script auto-disables
# the Exchange transport rule (so mail flows direct without signatures
# instead of piling up in queues). Default 3 = ~15 min on a 5-min cron.
# Set high (e.g. 999) to disable the auto-trigger entirely.
AUTO_DISABLE_FAILURE_THRESHOLD=3

# Azure AD app credentials for managing the transport rule. Required
# only if you want auto-disable / manual disable-and-enable scripts to
# work. See README "Azure AD app setup" for the one-time provisioning.
EXCHANGE_APP_ID=
EXCHANGE_APP_TENANT=
EXCHANGE_APP_CERT_PATH=/etc/mail-relay/exchange-app.pfx
# Leave blank if the .pfx has no password.
EXCHANGE_APP_CERT_PASSWORD=
# Override only if you renamed the rule from the default.
# EXCHANGE_RULE_NAME=Chaiiwala Signature Relay
