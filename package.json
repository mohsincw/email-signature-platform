{
  "name": "email-signature-platform",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @esp/api dev",
    "dev:admin": "pnpm --filter @esp/admin-web dev",
    "dev:mail": "pnpm --filter @esp/mail-processor dev",
    "dev": "pnpm run --parallel dev:api dev:admin dev:mail",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @esp/database generate",
    "db:migrate": "pnpm --filter @esp/database migrate",
    "db:seed": "pnpm --filter @esp/database seed",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "@nestjs/core"
    ]
  }
}
